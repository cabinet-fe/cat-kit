{
  "name": "cat-kit",
  "version": "1.0.0-alpha.1",
  "private": true,
  "description": "喵喵工具箱",
  "repository": {
    "type": "git",
    "url": "https://github.com/cabinet-fe/cat-kit"
  },
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "bunx oxfmt --write .",
    "changeset": "changeset",
    "release": "bun run scripts/release.ts",
    "sync-cat-kit-skills-api": "bun run scripts/sync-cat-kit-skills-api.ts",
    "sync-cat-kit-skills-api:build": "bun run scripts/sync-cat-kit-skills-api.ts -- --build"
  },
  "devDependencies": {
    "@cat-kit/tsconfig": "workspace:*",
    "@changesets/cli": "^2.29.6",
    "@tsdown/css": "^0.21.7",
    "@types/bun": "^1.3.11",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.14.2",
    "turbo": "^2.5.6",
    "typescript": "^6.0.2",
    "unplugin-vue": "^7.0.1",
    "vitest": "^4.1.2",
    "vue": "^3.5.31"
  },
  "packageManager": "bun@1.3.12"
}
