{
  "name": "@cat-kit/cli",
  "version": "1.0.6",
  "description": "CatKit CLI tools",
  "bin": {
    "cat-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    "./*": {
      "development": "./src/*",
      "import": "./dist/*",
      "types": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "bunx oxlint .",
    "test": "bunx vitest run --globals",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@cat-kit/tsconfig": "workspace:*",
    "@types/node": "^24.12.0"
  }
}
