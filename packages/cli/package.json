{
  "name": "@cat-kit/cli",
  "version": "1.0.4",
  "description": "CatKit CLI tools",
  "bin": {
    "cat-cli": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "lint": "bunx oxlint .",
    "test": "bunx vitest run --globals",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    "./src/*": {
      "import": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@cat-kit/tsconfig": "workspace:*",
    "@types/node": "^24.12.0"
  }
}
