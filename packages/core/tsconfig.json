{
  "extends": "@cat-kit/tsconfig/tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "customConditions": ["development"],
    "tsBuildInfoFile": "./node_modules/.cache/.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["tests", "**/*.test.ts", "**/*.spec.ts"]
}
