{
  "extends": "@cat-kit/tsconfig/tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true
  },
  "include": [
    "**/*.test.ts",
    "../be/src/**/*.ts",
    "../cli/src/**/*.ts",
    "../core/src/**/*.ts",
    "../fe/src/**/*.ts",
    "../http/src/**/*.ts"
  ]
}
